cmd-setmind-desc = Передає розум вказаній істоті. Сутність повинна мати {$requiredComponent}. За замовчуванням це примусово поверне розуми, які наразі відвідують інших сутностей (тобто поверне привида в основне тіло).
cmd-setmind-help = Використання: {$command} <entityUid> <username> [unvisit]
cmd-setmind-command-target-has-no-content-data-message = У цільового гравця немає content data (вона де?)
cmd-setmind-command-target-has-no-mind-message = У цільової сутності немає розуму (забув зробити її розумною?)
