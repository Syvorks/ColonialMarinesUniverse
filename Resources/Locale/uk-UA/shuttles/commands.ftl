# FTLdiskburner
cmd-ftldisk-desc = Створює FTL-диск з координатами для подорожі до мапи, на якій або в якій знаходиться вказаний EntityID
cmd-ftldisk-help = ftldisk [EntityID]

cmd-ftldisk-no-transform = Сутність {$destination} не має Transform Component!
cmd-ftldisk-no-map = Сутність {$destination} не має мапи!
cmd-ftldisk-no-map-comp = Сутність {$destination} якимось чином знаходиться на мапі {$map} без map component.
cmd-ftldisk-map-not-init = Сутність {$destination} на мапі {$map}, яка не ініціалізована! Переконайтесь, що її безпечно ініціалізувати, потім спершу ініціалізуйте мапу, інакше гравці застрягнуть на місці!
cmd-ftldisk-map-paused = Сутність {$desintation} на мапі {$map}, яка на паузі! Спершу зніміть паузу, інакше гравці застрягнуть на місці.
cmd-ftldisk-planet = Сутність {$desintation} на планетарній мапі {$map} і потребує FTL-точку. Можливо, вона вже існує.
cmd-ftldisk-already-dest-not-enabled = Сутність {$destination} на мапі {$map}, яка вже має FTLDestinationComponent, але він не Enabled! Встановіть це вручну з міркувань безпеки.
cmd-ftldisk-requires-ftl-point = Сутність {$destination} на мапі {$map}, яка потребує FTL-точку для подорожі! Можливо, вона вже існує.

cmd-ftldisk-hint = Map netID
