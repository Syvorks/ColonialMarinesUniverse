## Implanter Attempt Messages

implanter-component-implanting-target = {$user} намагається імплантувати тобі щось!
implanter-component-implant-failed = {$implant} не можна дати {$target}!
implanter-draw-failed-permanent = {$implant} в {$target} зрослося з { OBJECT($target) } і не може бути видалене!
implanter-draw-failed = Ти спробував витягнути імплант, але нічого не знайшов.
implanter-draw-failed-catastrophically = Імплантер нічого не знаходить і катастрофічно ламається, виплескуючи генетичний матеріал у руку {$user}!
implanter-component-implant-already = {$target} вже має {$implant}!

## UI
implanter-set-draw-verb = Налаштувати витягування імпланта
implanter-set-draw-window = Налаштувати витягування імпланта
implanter-set-draw-info = Оберіть тип імпланта, який цей імплантер повинен видаляти:
implanter-set-draw-type = Тип імпланта:

implanter-draw-text = Витягти
implanter-inject-text = Ввести

implanter-empty-text = Порожньо

implanter-label-inject = [color=green]{$implantName}[/color]
    Режим: [color=white]{$modeString}[/color]

implanter-label-draw = [color=red]{$implantName}[/color]
    Режим: [color=white]{$modeString}[/color]

implanter-contained-implant-text = [color=green]{$desc}[/color]

## Спливаючі вікна імпланта

scramble-implant-activated-popup = Твоя зовнішність змінюється і набуває нового вигляду!

## Повідомлення імпланта

deathrattle-implant-dead-message = {$user} помер {$position}.
deathrattle-implant-critical-message = У {$user} критичні життєві показники, потрібна негайна допомога {$position}.
