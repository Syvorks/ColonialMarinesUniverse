injector-component-draw-success-message = Ти набираєш {$amount}u з {THE($target)}.
injector-component-target-already-full-message = {CAPITALIZE(THE($target))} вже повний!
injector-component-target-is-empty-message = {CAPITALIZE(THE($target))} порожній!
injector-component-cannot-toggle-draw-message = Занадто повний, щоб набирати!
injector-component-cannot-toggle-inject-message = Нема чого ін'єктувати!

