### Solution transfer component

comp-solution-transfer-fill-normal = Ти наповнюєш {THE($target)} {$amount}u з {THE($owner)}.
comp-solution-transfer-fill-fully = Ти наповнюєш {THE($target)} до країв {$amount}u з {THE($owner)}.
comp-solution-transfer-transfer-solution = Ти переливаєш {$amount}u у {THE($target)}.

## Показується при спробі переливання у розчин, коли віддавач порожній або приймач повний
comp-solution-transfer-is-empty = {CAPITALIZE(THE($target))} порожній!
comp-solution-transfer-is-full = {CAPITALIZE(THE($target))} повний!

## Показується в назві дієслова зміни обсягу переливання
comp-solution-transfer-verb-custom-amount = Свій
comp-solution-transfer-verb-amount = {$amount}u
comp-solution-transfer-verb-toggle = Перемкнути на {$amount}u

## Показується після успішної зміни обсягу розчину через BUI
comp-solution-transfer-set-amount = Обсяг переливання встановлено на {$amount}u.
comp-solution-transfer-set-amount-max = Макс: {$amount}u
comp-solution-transfer-set-amount-min = Мін: {$amount}u

