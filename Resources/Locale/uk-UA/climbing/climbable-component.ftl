
### UI

# Verb name for climbing
comp-climbable-verb-climb = Перелізти

### Повідомлення взаємодії

# Показується тобі, коли твій персонаж залазить на $climbable
comp-climbable-user-climbs = Ти стрибаєш на { THE($climbable) }!

# Показується іншим, коли $user залазить на $climbable
comp-climbable-user-climbs-other = { CAPITALIZE(THE($user)) } стрибає на { THE($climbable) }!

# Показується тобі, коли твій персонаж примушує когось залізти на $climbable
comp-climbable-user-climbs-force = Ти запихаєш { THE($moved-user) } на { THE($climbable) }!

# Показується іншим, коли хтось примушує $moved-user залізти на $climbable
comp-climbable-user-climbs-force-other = { CAPITALIZE(THE($user)) } запихає { THE($moved-user) } на { THE($climbable) }!

# Показується тобі, коли твій персонаж задалеко від climbable
comp-climbable-cant-reach = Туди не дотягтись!

# Показується тобі, коли твій персонаж не може взаємодіяти з climbable з якоїсь причини
comp-climbable-cant-interact = Ти не можеш цього зробити!

# Показується тобі, коли твій персонаж не може залізти власними діями
comp-climbable-cant-climb = Ти не здатен залазити!

# Показується тобі, коли твій персонаж намагається запхати на climbable когось, хто не може лізти
comp-climbable-target-cant-climb = { CAPITALIZE(THE($moved-user)) } не може туди лізти!
