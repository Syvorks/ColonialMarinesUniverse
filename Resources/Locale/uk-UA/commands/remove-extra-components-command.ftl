cmd-removeextracomponents-desc = Видаляє всі компоненти з усіх сутностей з вказаним id, якщо такого компонента немає в прототипі.
Якщо id не вказано, застосовується до всіх сутностей.
cmd-removeextracomponents-help = removeextracomponents / removeextracomponents <entityId>
cmd-removeextracomponents-invalid-prototype-id = Не вдається знайти прототип сутності з id {$id}.
cmd-removeextracomponents-success = Видалено {$count} компонентів з {$entities},
cmd-removeextracomponents-success-with-id = Видалено {$count} компонентів з {$entities} з id {$id}.
