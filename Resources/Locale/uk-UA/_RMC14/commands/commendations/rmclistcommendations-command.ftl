# List Commendations Command
cmd-rmclistcommendations-desc = Виводить список відзнак за раундом, гравцем, ідентифікатором або останні записи.
cmd-rmclistcommendations-help = Використання:\n  rmclistcommendations last <кількість> [тип]\n    - Показує найновіші відзнаки\n    - кількість: скільки останніх відзнак показати\n    - тип: фільтр типу відзнаки (за замовчуванням всі)\n  \n  rmclistcommendations round <roundId> [тип]\n    - Показує всі відзнаки за конкретний раунд\n    - тип: фільтр типу відзнаки (за замовчуванням всі)\n\n  rmclistcommendations id <commendationId>\n    - Показує одну відзнаку за ідентифікатором\n  \n  rmclistcommendations player giver <usernameOrId> <кількість> [тип]\n    - Показує відзнаки, надані гравцем\n    - кількість: скільки останніх відзнак показати\n    - тип: фільтр типу відзнаки (за замовчуванням всі)\n  \n  rmclistcommendations player receiver <usernameOrId> <кількість> [тип]\n    - Показує відзнаки, отримані гравцем\n    - кількість: скільки останніх відзнак показати\n    - тип: фільтр типу відзнаки (за замовчуванням всі)
cmd-rmclistcommendations-invalid-arguments = Невірні аргументи!
cmd-rmclistcommendations-invalid-round-id = Невірний ідентифікатор раунду!
cmd-rmclistcommendations-invalid-id = Невірний ідентифікатор відзнаки!
cmd-rmclistcommendations-invalid-type = Невірний тип '{ $type }'!
cmd-rmclistcommendations-invalid-player-mode = Невірний режим гравця! Має бути 'giver' або 'receiver'.
cmd-rmclistcommendations-invalid-count = Невірна кількість! Має бути додатним числом.
cmd-rmclistcommendations-player-not-found = Гравця '{ $player }' не знайдено.
cmd-rmclistcommendations-no-results = Відзнак не знайдено
cmd-rmclistcommendations-last-header = Показано { $count } найновіших відзнак (запитано: { $total }):
cmd-rmclistcommendations-round-header = Відзнаки за Раунд { $round } ({ $count } всього):
cmd-rmclistcommendations-id-header = Відзнака { $id }:
cmd-rmclistcommendations-giver-header = Показано { $count } найновіших наданих відзнак (запитано: { $total }):
cmd-rmclistcommendations-receiver-header = Показано { $count } найновіших отриманих відзнак (запитано: { $total }):
cmd-rmclistcommendations-format = id [{ $id }] { $type }: { $name } - { $giverUserName } ({ $giver }) → { $receiverUserName } ({ $receiver }) Раунд { $round }: { $text }
cmd-rmclistcommendations-hint-mode = Режим (last, round, id або player)
cmd-rmclistcommendations-hint-mode-last = Показати найновіші відзнаки
cmd-rmclistcommendations-hint-mode-round = Показати відзнаки за раундом
cmd-rmclistcommendations-hint-mode-id = Показати відзнаку за ідентифікатором
cmd-rmclistcommendations-hint-mode-player = Показати відзнаки за гравцем
cmd-rmclistcommendations-hint-round-id = Ідентифікатор Раунду
cmd-rmclistcommendations-hint-commendation-id = Ідентифікатор Відзнаки
cmd-rmclistcommendations-hint-player-mode = Режим гравця (giver або receiver)
cmd-rmclistcommendations-hint-player-giver = Відзнаки, надані гравцем
cmd-rmclistcommendations-hint-player-receiver = Відзнаки, отримані гравцем
cmd-rmclistcommendations-hint-player = Ім'я користувача або UserId гравця
cmd-rmclistcommendations-hint-count = Кількість відзнак для показу
cmd-rmclistcommendations-hint-type = Фільтр типу відзнаки
