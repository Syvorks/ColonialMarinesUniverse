# addaction
cmd-addaction-desc = Додає дію до цільової сутності. Дія не працюватиме, якщо ціль потребує додатковий компонент на своїй сутності (наприклад, Dragon's Devour).
cmd-addaction-help = addaction <EntityUid> <ActionPrototype>

cmd-addaction-invalid-args = Очікується точно 2 аргументи.
cmd-addaction-actions-not-found = Цільова сутність не може використовувати дії.
cmd-addaction-action-not-found = Не вдалося знайти прототип дії {$action}, що збігається.
cmd-addaction-adding-failed = Не вдалося додати дію.

cmd-addaction-player-completion = <EntityUid>
cmd-addaction-action-completion = <ActionProto>
