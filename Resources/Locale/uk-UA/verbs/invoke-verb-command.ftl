### Localization used for the invoke verb command.
# Mostly help + error messages.

invoke-verb-command-description = Викликає дієслово з вказаним іменем на сутності, з сутністю гравця
invoke-verb-command-help = invokeverb <playerUid | "self"> <targetUid> <verbName | "interaction" | "activation" | "alternative">

invoke-verb-command-invalid-args = invokeverb приймає 2 аргументи.

invoke-verb-command-invalid-player-uid = Не вдалося розпарсити uid гравця, або не передано "self".
invoke-verb-command-invalid-target-uid = Не вдалося розпарсити uid цілі.

invoke-verb-command-invalid-player-entity = Вказаний uid гравця не відповідає валідній сутності.
invoke-verb-command-invalid-target-entity = Вказаний uid цілі не відповідає валідній сутності.

invoke-verb-command-success = Викликано дієслово "{ $verb }" на { $target } з користувачем { $player }.

invoke-verb-command-verb-not-found = Не вдалося знайти дієслово { $verb } на { $target }.
