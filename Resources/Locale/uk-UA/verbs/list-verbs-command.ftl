### Localization used for the list verbs command.
# Mostly help + error messages.

list-verbs-command-description = Перелічує всі дієслова, які гравець може використати на вказаній сутності.
list-verbs-command-help = listverbs <playerUid | "self"> <targetUid>

list-verbs-command-invalid-args = listverbs приймає 2 аргументи.

list-verbs-command-invalid-player-uid = Не вдалося розпарсити uid гравця, або не передано "self".
list-verbs-command-invalid-target-uid = Не вдалося розпарсити uid цілі.

list-verbs-command-invalid-player-entity = Вказаний uid гравця не відповідає валідній сутності.
list-verbs-command-invalid-target-entity = Вказаний uid цілі не відповідає валідній сутності.

list-verbs-verb-listing = { $type }: { $verb }
